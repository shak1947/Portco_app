# ── Model config ──────────────────────────────────────────────────────────────
MODEL=anthropic/claude-sonnet-4-6

# ── API keys ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
# GOOGLE_API_KEY=your-google-api-key
# OPENAI_API_KEY=your-openai-api-key

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ── Agent config ───────────────────────────────────────────────────────────────
MAX_ITERATIONS=10
MAX_TOKENS=4096
